#!/bin/bash
set -euo pipefail

json_file="config.json"

if ! command -v jq &> /dev/null; then
  echo "Error: jq is not installed. Install it via: brew install jq" >&2
  exit 1
fi

if ! command -v docker &> /dev/null; then
  echo "Error: Docker is not installed. Please install Docker Desktop." >&2
  exit 1
fi

usage() {
  cat <<EOF
Usage: $0 [-h]

Build a Docker image with Ruby and Rails installed, as configured in
$json_file. The image is tagged as both rails-docker (latest) and
rails-docker-<ruby_v>-<rails_v>.

Options:
  -h   Show this help message
EOF
  exit 0
}

while getopts ":h" opt; do
  case $opt in
    h) usage ;;
    \?) echo "Invalid option: -$OPTARG" >&2; usage ;;
  esac
done

if [ ! -f "$json_file" ]; then
  echo "Error: $json_file not found." >&2
  exit 1
fi

ruby_version=$(jq -r '.RUBY_IMAGE_VERSION // ""' "$json_file")
rails_version=$(jq -r '.RAILS_VERSION // ""' "$json_file")

ruby_version="${ruby_version:-latest}"
rails_version="${rails_version:-latest}"

echo "Ruby image version: $ruby_version"
echo "Rails version: $rails_version"

docker build -t rails-docker -t "rails-docker-$ruby_version-$rails_version" \
  --build-arg "ruby_image_version=$ruby_version" .
