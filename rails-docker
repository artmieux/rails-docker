#!/bin/bash
set -euo pipefail

default_image_tag="rails-docker"

usage() {
  cat <<EOF
Usage: $0 [-t ruby_v-rails_v] <rails_command> [rails_args...]

Run a Rails command inside a Docker container with the current directory
mounted as the working directory.

Options:
  -t TAG    Use image rails-docker-TAG instead of rails-docker (latest)
  -h        Show this help message

Examples:
  $0 new myapp --skip-bundle
  $0 -t 3.0.0-7.0.0 new myapp
  $0 generate scaffold Post title:string body:text
EOF
  exit 0
}

image_tag="$default_image_tag"

while getopts ":t:h" opt; do
  case $opt in
    t)
      image_tag="rails-docker-$OPTARG"
      ;;
    h)
      usage
      ;;
    \?)
      echo "Invalid option: -$OPTARG" >&2
      usage
      ;;
    :)
      echo "Option -$OPTARG requires an argument." >&2
      exit 1
      ;;
  esac
done
shift $((OPTIND-1))

if [ $# -eq 0 ]; then
  echo "Error: no rails command provided." >&2
  usage
fi

if ! command -v docker &> /dev/null; then
  echo "Error: Docker is not installed. Please install Docker before running this script." >&2
  exit 1
fi

if ! docker image inspect "$image_tag" &> /dev/null; then
  echo "Error: Docker image '$image_tag' not found. Build it first with: ./build-image" >&2
  exit 1
fi

exec docker run --rm -it -v "$(pwd):/usr/src" "$image_tag" rails "$@"
